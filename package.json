{
  "name": "flipper-cli-script-gen-eng",
  "version": "4.1.0",
  "description": "Safe keyboard automation generator for authorized lab/demo use",
  "type": "module",
  "main": "cli/index.js",
  "bin": {
    "flipper-safe-gen": "./cli/index.js"
  },
  "scripts": {
    "test": "node --test",
    "validate": "node cli/index.js --validate",
    "list": "node cli/index.js --list-templates",
    "search": "node cli/index.js --search os:windows",
    "preview": "node cli/index.js --preview windows-open-run-notepad --format flipper --os windows",
    "prompt": "node cli/index.js --prompt \"windows powershell get-date\" --format ducky --os windows",
    "batch": "node cli/index.js --batch projects/demo-batch.json",
    "project": "node cli/index.js --project demo-windows-project",
    "pack": "node cli/index.js --pack demo-windows-project",
    "web": "node web/server.js"
  },
  "keywords": [
    "flipper",
    "ducky",
    "keyboard",
    "automation",
    "safe"
  ],
  "license": "MIT"
}
